# ─── VoteLedger Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# Groq API key — powers the VoteLedger AI Advisor (llama-3.1-8b-instant)
# FREE tier — no credit card required. 6,000 requests/day.
# Get your free key at: https://console.groq.com
# Sign up → API Keys → Create API Key
GROQ_API_KEY="your_groq_api_key_here"

# Formspree form ID — powers both signup forms
# Must be prefixed VITE_ so Vite exposes it to the browser.
# Get a free form at: https://formspree.io
VITE_FORMSPREE_ID="your_formspree_form_id_here"

# Port for the Express dev server (optional — defaults to 3000)
PORT=3000

# Set to "production" when deploying
NODE_ENV="development"
